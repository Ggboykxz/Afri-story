rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============= HELPER FUNCTIONS =============
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getUserRole() {
      return getUserData().role;
    }
    
    function hasRole(roles) {
      return isSignedIn() && getUserRole() in roles;
    }
    
    function isValidString(value, maxLen) {
      return value is string && value.size() > 0 && value.size() <= maxLen;
    }
    
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_-]+$');
    }
    
    function noSensitiveFieldModification() {
      let sensitiveFields = ['afriCoins', 'subscription', 'subscriptionExpiresAt', 'badges', 'role', 'isVerified'];
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(sensitiveFields);
    }

    function isWorkAuthor(workId) {
      return get(/databases/$(database)/documents/works/$(workId)).data.authorId == request.auth.uid;
    }

    function hasUnlockedChapter(userId, chapterId) {
      return exists(/databases/$(database)/documents/users/$(userId)/unlocks/$(chapterId));
    }
    
    // ============= USERS =============
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || hasRole(['moderator', 'supervisor', 'admin']));
      allow create: if isSignedIn() && isOwner(userId)
        && isValidString(request.resource.data.displayName, 100)
        && request.resource.data.role in ['visitor', 'reader']
        && request.resource.data.afriCoins == 100 // Allow initial bonus
        && (!('isVerified' in request.resource.data) || request.resource.data.isVerified == false);
      allow update: if isSignedIn() && isOwner(userId) && noSensitiveFieldModification();
      allow delete: if isSignedIn() && (isOwner(userId) || hasRole(['admin']));
      
      match /favorites/{favoriteId} {
        allow read: if isSignedIn() && isOwner(userId);
        allow create, delete: if isSignedIn() && isOwner(userId);
      }
      
      match /reading_history/{historyId} {
        allow read: if isSignedIn() && isOwner(userId);
        allow create, delete: if isSignedIn() && isOwner(userId);
      }
      
      match /unlocks/{unlockId} {
        allow read: if isSignedIn() && isOwner(userId);
        allow create: if isSignedIn() && isOwner(userId);
        allow delete: if false;
      }

      match /coin_purchases/{purchaseId} {
        allow read: if isSignedIn() && isOwner(userId);
        allow create: if false; // Should only be via admin or functions
      }
    }
    
    // ============= WORKS =============
    match /works/{workId} {
      allow read: if true;
      allow create: if isSignedIn() && hasRole(['artist_draft', 'artist_pro', 'artist_mentor'])
        && isValidString(request.resource.data.title, 200)
        && request.resource.data.authorId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.authorId == request.auth.uid || hasRole(['moderator', 'supervisor', 'admin']));
      allow delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || hasRole(['admin']));
      
      match /chapters/{chapterId} {
        allow read: if resource.data.isPremium == false
          || (isSignedIn() && (isWorkAuthor(workId) || hasUnlockedChapter(request.auth.uid, chapterId) || hasRole(['moderator', 'supervisor', 'admin'])));

        allow create: if isSignedIn() && isWorkAuthor(workId)
          && isValidString(request.resource.data.title, 200)
          && request.resource.data.number is int;
        allow update, delete: if isSignedIn() && (isWorkAuthor(workId) || hasRole(['moderator', 'supervisor', 'admin']));
        
        match /comments/{commentId} {
          allow read: if true;
          allow create: if isSignedIn()
            && isValidString(request.resource.data.content, 2000)
            && request.resource.data.userId == request.auth.uid;
          allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || hasRole(['moderator', 'supervisor', 'admin']));
        }
      }
      
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn()
          && request.resource.data.rating is int
          && request.resource.data.rating >= 1
          && request.resource.data.rating <= 5
          && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || hasRole(['moderator', 'supervisor', 'admin']));
      }
    }
    
    // ============= FORUMS =============
    match /forums/{forumId} {
      allow read: if true;
      allow create, update, delete: if hasRole(['moderator', 'supervisor', 'admin']);

      match /posts/{postId} {
        allow read: if true;
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || hasRole(['moderator', 'supervisor', 'admin']));
      }
    }
    
    match /forum_threads/{threadId} {
      allow read: if true;
      allow create: if isSignedIn()
        && isValidString(request.resource.data.title, 200)
        && request.resource.data.authorId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.authorId == request.auth.uid || hasRole(['moderator', 'supervisor', 'admin']));
      allow delete: if hasRole(['moderator', 'supervisor', 'admin']);
    }
    
    match /forum_replies/{replyId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.authorId == request.auth.uid || hasRole(['moderator', 'supervisor', 'admin']));
      allow delete: if hasRole(['moderator', 'supervisor', 'admin']);
    }
    
    // ============= NOTIFICATIONS =============
    match /notifications/{notificationId} {
      allow read, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if hasRole(['moderator', 'supervisor', 'admin']);
    }
    
    // ============= CONVERSATIONS =============
    match /conversations/{conversationId} {
      allow read, update, delete: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;
      
      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
        allow create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants
          && request.resource.data.senderId == request.auth.uid;
      }
    }

    // ============= COLLECTIONS =============
    match /collections/{collectionId} {
      allow read: if !resource.data.isPrivate || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ============= BOOK CLUBS =============
    match /book_clubs/{clubId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.creatorId == request.auth.uid || request.auth.uid in resource.data.memberIds);
      allow delete: if isSignedIn() && resource.data.creatorId == request.auth.uid;
    }

    // ============= CONTESTS =============
    match /contests/{contestId} {
      allow read: if true;
      allow create, update, delete: if hasRole(['moderator', 'supervisor', 'admin']);
    }

    // ============= REPORTS =============
    match /reports/{reportId} {
      allow read: if hasRole(['moderator', 'supervisor', 'admin']);
      allow create: if isSignedIn() && request.resource.data.reporterId == request.auth.uid;
    }

    match /verification_requests/{requestId} {
      allow read: if hasRole(['moderator', 'supervisor', 'admin']) || (isSignedIn() && resource.data.artistId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.artistId == request.auth.uid;
      allow update: if hasRole(['moderator', 'supervisor', 'admin']);
    }
    
    match /featured_content/{contentId} {
      allow read: if true;
      allow write: if hasRole(['admin']);
    }

    // Catch-all default
    match /{allPaths=**} {
      allow read: if isSignedIn() && hasRole(['admin']);
      allow write: if isSignedIn() && hasRole(['admin']);
    }
  }
}
