rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============= HELPER FUNCTIONS =============
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function hasRole(roles) {
      return isSignedIn() && getUserRole() in roles;
    }
    
    function isValidString(value, maxLen) {
      return value is string && value.size() > 0 && value.size() <= maxLen;
    }
    
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_-]+$');
    }
    
    function isValidTimestamp(field) {
      return field is timestamp;
    }
    
    function noRoleEscalation() {
      return request.resource.data.role == resource.data.role
        || (!('role' in request.resource.data) && resource.data.role == getUserRole());
    }
    
    function noSensitiveFieldModification() {
      return !('afriCoins' in request.resource.data)
        && !('subscription' in request.resource.data)
        && !('subscriptionExpiresAt' in request.resource.data)
        && !('badges' in request.resource.data)
        && !('role' in request.resource.data);
    }
    
    // ============= USERS =============
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || hasRole(['moderator', 'supervisor', 'admin']));
      allow create: if isSignedIn() && isOwner(userId)
        && isValidString(request.resource.data.displayName, 100)
        && request.resource.data.role in ['visitor', 'reader'];
      allow update: if isSignedIn() && isOwner(userId) && noSensitiveFieldModification()
        && (!('role' in request.resource.data) || request.resource.data.role == resource.data.role)
        && (!('afriCoins' in request.resource.data) || request.resource.data.afriCoins == resource.data.afriCoins);
      allow delete: if isSignedIn() && (isOwner(userId) || hasRole(['admin']));
      
      match /favorites/{favoriteId} {
        allow read: if isSignedIn() && isOwner(userId);
        allow create: if isSignedIn() && isOwner(userId);
        allow delete: if isSignedIn() && isOwner(userId);
      }
      
      match /reading_history/{historyId} {
        allow read: if isSignedIn() && isOwner(userId);
        allow create: if isSignedIn() && isOwner(userId);
        allow delete: if isSignedIn() && isOwner(userId);
      }
      
      match /unlocks/{unlockId} {
        allow read: if isSignedIn() && isOwner(userId);
        allow create: if isSignedIn() && isOwner(userId);
        allow delete: if false;
      }
    }
    
    // ============= WORKS =============
    match /works/{workId} {
      allow read: if true;
      allow create: if isSignedIn() && hasRole(['artist_draft', 'artist_pro', 'artist_mentor'])
        && isValidString(request.resource.data.title, 200)
        && isValidString(request.resource.data.description, 5000)
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.createdAt == request.time;
      allow update: if isSignedIn() && (resource.data.authorId == request.auth.uid || hasRole(['moderator', 'supervisor', 'admin']));
      allow delete: if isSignedIn() && (resource.data.authorId == request.auth.uid || hasRole(['admin']));
      
      match /chapters/{chapterId} {
        allow read: if true;
        allow create: if isSignedIn() && hasRole(['artist_draft', 'artist_pro', 'artist_mentor'])
          && isValidString(request.resource.data.title, 200)
          && request.resource.data.number is int
          && request.resource.data.number > 0;
        allow update: if isSignedIn() && hasRole(['artist_draft', 'artist_pro', 'artist_mentor', 'moderator', 'supervisor', 'admin']);
        allow delete: if isSignedIn() && hasRole(['artist_draft', 'artist_pro', 'artist_mentor', 'moderator', 'supervisor', 'admin']);
        
        match /comments/{commentId} {
          allow read: if true;
          allow create: if isSignedIn()
            && isValidString(request.resource.data.content, 2000)
            && request.resource.data.userId == request.auth.uid
            && request.resource.data.createdAt == request.time;
          allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || hasRole(['moderator', 'supervisor', 'admin']));
        }
      }
      
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn()
          && request.resource.data.rating is int
          && request.resource.data.rating >= 1
          && request.resource.data.rating <= 5
          && (!('comment' in request.resource.data) || request.resource.data.comment.size() <= 2000)
          && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || hasRole(['moderator', 'supervisor', 'admin']));
      }
      
      match /exclusives/{exclusiveId} {
        allow read: if hasRole(['reader_premium', 'reader_supporter', 'artist_pro', 'artist_mentor', 'enterprise']) || resource.data.usedBy[request.auth.uid] == true;
        allow create: if isSignedIn() && hasRole(['artist_pro', 'artist_mentor']) && resource.data.authorId == request.auth.uid;
      }
    }
    
    // ============= FORUMS =============
    match /forums/{forumId} {
      allow read: if true;
      allow create, update, delete: if isSignedIn() && hasRole(['moderator', 'supervisor', 'admin']);
    }
    
    match /forum_threads/{threadId} {
      allow read: if true;
      allow create: if isSignedIn()
        && isValidString(request.resource.data.title, 200)
        && isValidString(request.resource.data.content, 10000)
        && (!resource.data.get('isLocked', false));
      allow update: if isSignedIn() && hasRole(['moderator', 'supervisor', 'admin']) || (isSignedIn() && resource.data.authorId == request.auth.uid);
      allow delete: if isSignedIn() && hasRole(['moderator', 'supervisor', 'admin']);
    }
    
    match /forum_replies/{replyId} {
      allow read: if true;
      allow create: if isSignedIn()
        && isValidString(request.resource.data.content, 5000)
        && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isSignedIn() && hasRole(['moderator', 'supervisor', 'admin']) || (isSignedIn() && resource.data.authorId == request.auth.uid);
    }
    
    // ============= NOTIFICATIONS =============
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && hasRole(['moderator', 'supervisor', 'admin']);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
    
    // ============= CONVERSATIONS =============
    match /conversations/{conversationId} {
      allow read: if isSignedIn() && resource.data.participants[request.auth.uid] == true;
      allow create: if isSignedIn()
        && request.resource.data.participants[request.auth.uid] == true
        && request.resource.data.participants.size() >= 2;
      allow update: if isSignedIn() && resource.data.participants[request.auth.uid] == true;
      allow delete: if isSignedIn() && resource.data.participants[request.auth.uid] == true;
      
      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && request.resource.data.senderId == request.auth.uid
          && isValidString(request.resource.data.content, 5000);
        allow update, delete: if false;
      }
    }
    
    // ============= COLLECTIONS =============
    match /collections/{collectionId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
    
    // ============= BOOK CLUBS =============
    match /book_clubs/{clubId} {
      allow read: if true;
      allow create: if isSignedIn() && hasRole(['reader_premium', 'reader_supporter', 'artist_pro']);
      allow update: if isSignedIn() && resource.data.members[request.auth.uid] == true;
      allow delete: if isSignedIn() && hasRole(['artist_pro', 'moderator', 'admin']);
    }
    
    // ============= CONTESTS =============
    match /contests/{contestId} {
      allow read: if true;
      allow create: if isSignedIn() && hasRole(['artist_pro', 'moderator', 'admin']);
      allow update: if isSignedIn() && hasRole(['moderator', 'supervisor', 'admin']);
      allow delete: if isSignedIn() && hasRole(['admin']);
    }
    
    // ============= AMA SESSIONS =============
    match /ama_sessions/{sessionId} {
      allow read: if true;
      allow create: if isSignedIn() && hasRole(['artist_pro', 'artist_mentor']);
      allow update: if isSignedIn() && hasRole(['artist_pro', 'artist_mentor']) && resource.data.artistId == request.auth.uid;
      allow delete: if isSignedIn() && hasRole(['artist_pro', 'artist_mentor']) && resource.data.artistId == request.auth.uid;
    }
    
    // ============= SCHEDULED CHAPTERS =============
    match /scheduled_chapters/{chapterId} {
      allow read: if true;
      allow create: if isSignedIn() && hasRole(['artist_draft', 'artist_pro', 'artist_mentor']);
      allow update, delete: if isSignedIn() && hasRole(['artist_draft', 'artist_pro', 'artist_mentor']) && resource.data.authorId == request.auth.uid;
    }
    
    // ============= RECRUITMENT ADS =============
    match /recruitment_ads/{adId} {
      allow read: if true;
      allow create: if isSignedIn() && hasRole(['artist_draft', 'artist_pro', 'artist_mentor']);
      allow update, delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }
    
    // ============= TEAM MEMBERS =============
    match /team_members/{memberId} {
      allow read: if true;
      allow create: if isSignedIn() && hasRole(['artist_pro', 'artist_mentor']);
      allow update, delete: if isSignedIn() && hasRole(['artist_pro', 'artist_mentor', 'admin']);
    }
    
    // ============= REPORTS =============
    match /reports/{reportId} {
      allow read: if isSignedIn() && hasRole(['moderator', 'supervisor', 'admin']);
      allow create: if isSignedIn()
        && isValidString(request.resource.data.reason, 500);
      allow update, delete: if isSignedIn() && hasRole(['moderator', 'supervisor', 'admin']);
    }
    
    // ============= MODERATION ACTIONS =============
    match /moderation_actions/{actionId} {
      allow read: if isSignedIn() && hasRole(['moderator', 'supervisor', 'admin']);
      allow create: if isSignedIn() && hasRole(['moderator', 'supervisor', 'admin']);
      allow delete: if isSignedIn() && hasRole(['admin']);
    }
    
    // ============= VERIFICATION REQUESTS =============
    match /verification_requests/{requestId} {
      allow read: if isSignedIn() && (hasRole(['moderator', 'supervisor', 'admin']) || resource.data.artistId == request.auth.uid);
      allow create: if isSignedIn() && hasRole(['artist_draft']);
      allow update: if isSignedIn() && hasRole(['moderator', 'supervisor', 'admin']);
      allow delete: if isSignedIn() && resource.data.artistId == request.auth.uid;
    }
    
    // ============= AFRICOINS TRANSACTIONS =============
    match /africoins_transactions/{transactionId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && hasRole(['admin']);
      allow update, delete: if false;
    }
    
    // ============= COMMENT REACTIONS =============
    match /comment_reactions/{reactionId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
    
    // ============= FCM TOKENS =============
    match /fcmTokens/{userId} {
      allow read: if isSignedIn() && isOwner(userId);
      allow create, update: if isSignedIn() && isOwner(userId);
      allow delete: if isSignedIn() && isOwner(userId);
    }
    
    // ============= ANALYTICS =============
    match /analytics/{analyticId} {
      allow read: if isSignedIn() && hasRole(['artist_pro', 'artist_mentor', 'moderator', 'supervisor', 'admin']);
      allow create: if false;
      allow update, delete: if false;
    }
    
    // ============= FEATURED CONTENT =============
    match /featured_content/{contentId} {
      allow read: if true;
      allow create, update, delete: if isSignedIn() && hasRole(['admin']);
    }
  }
}
