rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper to check if user is author of a work
    function isWorkAuthor(workId) {
      return firestore.get(/databases/(default)/documents/works/$(workId)).data.authorId == request.auth.uid;
    }

    // User avatars
    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null 
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    
    // Work covers
    match /covers/{workId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && isWorkAuthor(workId)
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    
    // Chapter images
    match /chapters/{workId}/{chapterId}/{allPaths=**} {
      allow read: if true; // In prod, this might be restricted to readers
      allow write: if request.auth != null
        && isWorkAuthor(workId)
        && request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    
    // Merchandise images
    match /merchandise/{productId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && (firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin')
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    
    // Contest entries
    match /contests/{contestId}/{entryId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == entryId
        && request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    
    // Default rule - deny all
    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}